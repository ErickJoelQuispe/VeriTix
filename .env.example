# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=veritix_db
POSTGRES_USER=veritix_user
POSTGRES_PASSWORD=strongpassword

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=veritix_redis_secret

# ── Frontend URLs ─────────────────────────────────────────────────────────────
# En local:
NUXT_APP_BASE_URL=/
NUXT_PUBLIC_API_BASE=http://localhost:3001/api/v1
NUXT_BACKEND_API_BASE=http://backend:3001/api/v1

# En producción (cwtg.xyz):
# NUXT_APP_BASE_URL=/verifront/
# NUXT_PUBLIC_API_BASE=https://cwtg.xyz/veriback/api/v1
# NUXT_BACKEND_API_BASE=https://cwtg.xyz/veriback/api/v1
