FROM oven/bun:1-alpine AS deps
WORKDIR /app
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

FROM oven/bun:1-alpine AS prod-deps
WORKDIR /app
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile --production

FROM oven/bun:1-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY package.json bun.lock ./
COPY prisma ./prisma
COPY prisma.config.ts ./
COPY nest-cli.json tsconfig*.json ./
COPY src ./src

# Genera el cliente de Prisma
RUN bunx prisma generate --schema=./prisma/schema.prisma

# Limita el heap durante el build de TypeScript
ENV NODE_OPTIONS="--max-old-space-size=1024"
RUN bun run build

FROM oven/bun:1-alpine AS production
WORKDIR /app

RUN addgroup --system --gid 1001 nestjs \
 && adduser --system --uid 1001 nestjs

# Solo prod deps + dist compilado + prisma schema para las migraciones
COPY --from=prod-deps --chown=nestjs:nestjs /app/node_modules ./node_modules
COPY --from=builder --chown=nestjs:nestjs /app/dist ./dist
COPY --from=builder --chown=nestjs:nestjs /app/prisma ./prisma
COPY --from=builder --chown=nestjs:nestjs /app/src/generated ./src/generated
COPY --from=builder --chown=nestjs:nestjs /app/package.json ./package.json
# Config de Prisma sin dotenv — lee DATABASE_URL directo del environment
COPY --chown=nestjs:nestjs prisma.config.prod.ts ./prisma.config.ts

ENV NODE_ENV=production

USER nestjs

EXPOSE 3001

# Corre migraciones pendientes y luego arranca en modo producción (sin watch)
CMD ["sh", "-c", "bunx prisma migrate deploy && node dist/main.js"]
