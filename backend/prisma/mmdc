#!/usr/bin/env bash
set -euo pipefail

REAL_MMDC="$(dirname "$0")/../node_modules/.bin/mmdc"
OUTPUT=""

for ((i=1; i<=$#; i++)); do
  if [[ "${!i}" == "-o" && $((i + 1)) -le $# ]]; then
    j=$((i + 1))
    OUTPUT="${!j}"
    break
  fi
done

if [[ "$OUTPUT" == *.pdf ]]; then
  exec "$REAL_MMDC" -f "$@"
fi

exec "$REAL_MMDC" "$@"
